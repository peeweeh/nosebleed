# Copy this to .env.local (gitignored, never committed)
# Set AI_PROVIDER to: openai | bedrock | ollama

AI_PROVIDER=openai

# --- OpenAI-compatible endpoint (AI_PROVIDER=openai) ---
AI_API_BASE=https://your-endpoint/v1
AI_API_KEY=your-api-key
AI_MODEL_ID=claude-4.6-sonnet

# --- AWS Bedrock (AI_PROVIDER=bedrock) ---
# AWS_PROFILE=default
# AWS_REGION=us-east-1
# AWS_MODEL_ID=anthropic.claude-haiku-4-5

# --- Ollama (AI_PROVIDER=ollama) ---
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3

# --- Reasoning (all providers) ---
AI_REASONING_ENABLED=false
AI_REASONING_BUDGET=1024
